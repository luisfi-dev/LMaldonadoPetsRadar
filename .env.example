# Puerto donde se sirve la API (rutas bajo el prefijo /api)
PORT=3000

# Token de la API de Mapbox
MAPBOX_TOKEN=

# Credenciales del servicio de email (Nodemailer)
MAILER_EMAIL=
MAILER_PASSWORD=
MAILER_SERVICE=gmail

# PostgreSQL + PostGIS
# Para correr local con docker-compose usa DB_HOST=localhost.
# Dentro de docker-compose el servicio app usa DB_HOST=postgres.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=pet_radar

# Redis
# Local: REDIS_HOST=localhost. En docker-compose el app usa REDIS_HOST=redis.
REDIS_HOST=localhost
REDIS_PORT=6379

# Azure Application Insights
APPINSIGHTS_CONNECTION_STRING=
